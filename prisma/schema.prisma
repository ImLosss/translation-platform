// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int          @id @default(autoincrement())

  email         String       @unique
  username      String?

  passwordHash  String?

  googleId      String?      @unique

  balance       Float        @default(0)

  provider      AuthProvider @default(LOCAL)

  role          Role         @default(USER)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  glossaries    Glossary[]
  translations Translation[]
}

enum Role {
  USER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model Glossary {
  id               Int      @id @default(autoincrement())

  name             String

  sourceLanguage   String
  targetLanguage   String

  userId           Int
  user             User     @relation(fields: [userId], references: [id])

  entries          GlossaryEntry[]

  createdAt        DateTime @default(now())
}

model GlossaryEntry {
  id           Int       @id @default(autoincrement())

  source       String
  target       String

  detail       String?

  glossaryId   Int
  glossary     Glossary  @relation(fields: [glossaryId], references: [id], onDelete: Cascade)
}

model Translation {
  id          Int    @id @default(autoincrement())
  
  userId      Int
  user        User   @relation(fields: [userId], references: [id])

  fileName    String 
  videoSource String?

  sourceLang  String  
  targetLang  String   
  batchSize   Int     @default(50)
  totalCost   Float   @default(0)
  totalTokens Int     @default(0)

  status      TranslationStatus @default(PROCESSING)   

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  rows        TranslationRow[]
}

enum TranslationStatus {
  PROCESSING
  COMPLETED
  ERROR
}


model TranslationRow {
  id            Int      @id @default(autoincrement())
  translationId Int      
  
  sequence      Int   
  startTime     String  
  endTime       String   
  
  // Memisahkan teks asli dan hasil terjemahan
  sourceText    String   @db.Text 
  targetText    String?  @db.Text 
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  translation   Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)

  @@index([translationId]) 
}

model Provider {
  id      Int    @id @default(autoincrement())
  name    String
  pricing Float  @default(0)
}